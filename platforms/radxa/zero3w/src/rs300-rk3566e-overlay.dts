// SPDX-License-Identifier: GPL-2.0
/*
 * Device tree overlay for RS300 thermal camera on Radxa ZERO 3W (RK3566E)
 *
 * Connection: RS300 50-pin → Mini2 MIPI adapter PCB (15-pin FPC)
 *             → 22-to-15 adapter cable → Zero 3W 22-pin CSI connector
 *
 * Pipeline: rs300 (i2c2@0x3c) → csi2_dphy1 (split mode, lanes 0-1)
 *           → mipi_csi2 host bridge → rkcif_mipi_lvds → /dev/videoN
 *
 * I2C bus: i2c2 (M1 mux) — routed to CSI connector pins 20/21
 *          → 22→15 adapter → FPC pins 13/14 → R6/R7 100Ω → camera I2C
 *
 * Reset: GPIO3_C1 (CAMERAB_PDN_L, VCCIO6 domain) — CSI connector pin 17
 *        → 22→15 adapter → FPC pin 11 (CAM_GPIO) → R3 100Ω → NRST
 *
 * Power: Camera is self-powered — CSI connector 3.3V → adapter board
 *        LN3608AR-G boost → 5V to camera module. The regulator-supply
 *        phandles below satisfy the driver's regulator_bulk_get() but
 *        do not actually power the camera (all are always-on PMIC rails).
 *
 * Clock: CIF_CLKOUT (GPIO4_C1) is on the 22-pin CSI connector (pin 18)
 *        but NOT routed through the 22→15 adapter cable (RPi CSI pinout
 *        has no clock output). RS300 uses an internal oscillator — the
 *        driver does not call clk_get(), so this is not a problem.
 *
 * Reference: Zero 3W V1.12 schematic (sheet 09, RK3566_VI Interface)
 *            Mini2(WN2) MIPI adapter schematic
 *            docs/kernel-research/kernel-reference/dt-bindings.md
 */

/dts-v1/;
/plugin/;

#include <dt-bindings/clock/rk3568-cru.h>
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/pinctrl/rockchip.h>

/ {
	metadata {
		title = "Enable RS300 Thermal Camera";
		compatible = "radxa,zero3";
		category = "camera";
		exclusive = "csi2_dphy1";
		description = "Enable Infisense RS300 thermal camera via Mini2 MIPI adapter on CSI connector.";
	};
};

/* -----------------------------------------------------------------
 * CSI-2 D-PHY hardware block (shared register file at 0xfe870000).
 * Must be enabled when any of csi2_dphy0/1/2 are used.
 * ----------------------------------------------------------------- */
&csi2_dphy_hw {
	status = "okay";
};

/* -----------------------------------------------------------------
 * Disable full-mode DPHY (mutually exclusive with split mode).
 * csi2_dphy0 uses all 4 lanes; csi2_dphy1+2 each use 2 lanes.
 * ----------------------------------------------------------------- */
&csi2_dphy0 {
	status = "disabled";
};

/* -----------------------------------------------------------------
 * CSI-2 D-PHY split-mode instance 1 — physical lanes 0 & 1.
 * Used for a 2-lane sensor (RS300 uses 2 MIPI data lanes).
 * ----------------------------------------------------------------- */
&csi2_dphy1 {
	status = "okay";

	ports {
		#address-cells = <1>;
		#size-cells = <0>;

		/* port@0 — upstream (sensor) side */
		port@0 {
			reg = <0>;
			#address-cells = <1>;
			#size-cells = <0>;

			mipi_in_rs300: endpoint@1 {
				reg = <1>;
				remote-endpoint = <&rs300_out>;
				data-lanes = <1 2>;
			};
		};

		/* port@1 — downstream toward MIPI CSI-2 host bridge */
		port@1 {
			reg = <1>;
			#address-cells = <1>;
			#size-cells = <0>;

			dphy1_out: endpoint@1 {
				reg = <1>;
				remote-endpoint = <&mipi_csi2_input>;
			};
		};
	};
};

/* -----------------------------------------------------------------
 * MIPI CSI-2 host bridge (mipi_csi2 + mipi_csi2_hw in BSP).
 * Sits between D-PHY and RKCIF.
 * input endpoint is @1 (not @0) — BSP convention.
 * ----------------------------------------------------------------- */
&mipi_csi2 {
	status = "okay";

	ports {
		#address-cells = <1>;
		#size-cells = <0>;

		/* port@0 — input from D-PHY */
		port@0 {
			reg = <0>;
			#address-cells = <1>;
			#size-cells = <0>;

			mipi_csi2_input: endpoint@1 {
				reg = <1>;
				remote-endpoint = <&dphy1_out>;
				data-lanes = <1 2>;
			};
		};

		/* port@1 — output to RKCIF (single endpoint, no reg needed) */
		port@1 {
			reg = <1>;

			mipi_csi2_output: endpoint {
				remote-endpoint = <&cif_mipi_in>;
				data-lanes = <1 2>;
			};
		};
	};
};

/* -----------------------------------------------------------------
 * RKCIF hardware register block.
 * Must be enabled alongside rkcif_mmu.
 * ----------------------------------------------------------------- */
&rkcif {
	status = "okay";
};

/* -----------------------------------------------------------------
 * RKCIF MIPI/LVDS logical interface — the V4L2 video device.
 * ----------------------------------------------------------------- */
&rkcif_mipi_lvds {
	status = "okay";

	port {
		cif_mipi_in: endpoint {
			remote-endpoint = <&mipi_csi2_output>;
			data-lanes = <1 2>;
		};
	};
};

/* -----------------------------------------------------------------
 * RKCIF IOMMU — required for DMA to system RAM.
 * ----------------------------------------------------------------- */
&rkcif_mmu {
	status = "okay";
};

/* -----------------------------------------------------------------
 * RS300 sensor node on I2C bus 2 (M1 mux).
 *
 * Signal path (from Zero 3W V1.12 schematic, sheet 09):
 *   I2C2_SCL_M1 / I2C2_SDA_M1 (VCCIO6, 2.2K pull-ups to VCC_3V3)
 *   → CSI connector pins 20/21 → 22→15 adapter cable
 *   → FPC pins 13/14 → R6/R7 100Ω → camera I2C_SLV_SCK/SDA
 *
 * I2C address: 0x3c (7-bit).
 * ----------------------------------------------------------------- */
&i2c2 {
	status = "okay";
	pinctrl-names = "default";
	pinctrl-0 = <&i2c2m1_xfer>;
	#address-cells = <1>;
	#size-cells = <0>;

	rs300: rs300@3c {
		compatible = "infisense,rs300";
		reg = <0x3c>;

		/*
		 * Reference clock — RS300 has an internal oscillator and the
		 * driver does not call clk_get(). CIF_CLKOUT (GPIO4_C1) is on
		 * the 22-pin CSI connector (pin 18) but is NOT routed through
		 * the 22→15 adapter cable. Declared here for completeness.
		 */
		clocks = <&cru CLK_CIF_OUT>;
		clock-names = "xvclk";

		/*
		 * Power supplies — the camera is actually self-powered:
		 *   CSI connector VCC_3V3 (pin 22) → adapter board LN3608AR-G
		 *   boost converter → 5V to camera module (VDD_5V0_OUT)
		 *
		 * These PMIC phandles satisfy the driver's regulator_bulk_get()
		 * requirement. All three are always-on rails, so enable/disable
		 * calls are effectively no-ops — which is correct since the
		 * camera manages its own power from the 5V input.
		 */
		avdd-supply  = <&vcc2v8_dvp>;
		dovdd-supply = <&vcc1v8_dvp>;
		dvdd-supply  = <&vcc_1v8>;

		/*
		 * Reset GPIO — omitted. NRST on the RS300 has an internal
		 * pull-up and the datasheet says "leave floating if unused".
		 * GPIO3_C1 (CAMERAB_PDN_L) stays as default input; NRST
		 * floats high → camera runs normally without reset control.
		 *
		 * If reset control is needed later, add:
		 *   reset-gpios = <&gpio3 RK_PC1 GPIO_ACTIVE_LOW>;
		 * and fix the driver to use GPIOD_OUT_LOW (deasserted at
		 * probe), then pulse assert/deassert in power_on().
		 *
		 * Signal path: GPIO3_C1 → CSI pin 17 → 22→15 adapter
		 * → FPC pin 11 (CAM_GPIO) → R3 100Ω → NRST
		 */

		/* Rockchip camera module metadata consumed by camera HAL */
		rockchip,camera-module-index = <0>;
		rockchip,camera-module-facing = "back";
		rockchip,camera-module-name = "RS300";
		rockchip,camera-module-lens-name = "default";

		port {
			rs300_out: endpoint {
				remote-endpoint = <&mipi_in_rs300>;
				data-lanes = <1 2>;
				link-frequencies = /bits/ 64 <80000000>;
			};
		};
	};
};
